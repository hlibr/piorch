{
  "name": "default",
  "goal": "Implement the requested project features using PM → Dev → Verifier waves.",
  "maxWaves": 10,
  "maxTaskRetries": 3,
  "parallelism": 2,
  "allowedExtensions": [],
  "agents": {
    "pm": "pm",
    "developer": "developer",
    "verifier": "verifier"
  },
  "waveSource": {
    "type": "pm"
  },
  "taskFlow": {
    "stages": [
      {
        "id": "develop",
        "agent": "developer",
        "inputTemplate": "Task: {{task.title}}\n{{task.description}}\nIssues: {{task.issues}}",
        "outputSchema": {
          "status": "done",
          "summary": "string",
          "filesChanged": "string[]",
          "notes": "string"
        }
      },
      {
        "id": "verify",
        "agent": "verifier",
        "inputTemplate": "Verify task {{task.title}}. Dev summary: {{task.dev.summary}}",
        "outputSchema": {
          "status": "pass|fail",
          "issues": "string[]"
        },
        "transitions": [
          {"when": {"field": "status", "equals": "fail"}, "next": "develop"},
          {"when": {"field": "status", "equals": "pass"}, "next": "complete"}
        ]
      }
    ]
  }
}
